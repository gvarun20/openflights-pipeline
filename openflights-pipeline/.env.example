# Copy to .env — used by local Python AND Docker Compose
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openflights_dw
DB_USER=openflights
DB_PASSWORD=openflights

# pgAdmin (dev profile only)
PGADMIN_EMAIL=admin@openflights.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Local nginx dashboard (dev profile)
DASHBOARD_PORT=8080

# Docker export job — path inside container (set automatically in compose)
# DOCS_DIR=/docs
